rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} { allow create: if request.auth != null && request.auth.uid == uid; allow read: if request.auth != null && request.auth.uid == uid; }
    match /settings/{id} { allow create, read: if request.auth != null; }
    match /{document=**} { allow read, write: if false; }
  }
}
