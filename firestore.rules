rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function me() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isAdmin() { return signedIn() && me().data.role == 'admin'; }
    function myMemberNo() { return me().data.memberNo; }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    match /loginIndex/{hash} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }
    match /settings/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /members/{memberNo} {
      allow read: if isAdmin() || (signedIn() && myMemberNo() == memberNo);
      allow write: if isAdmin();
    }
  }
}
